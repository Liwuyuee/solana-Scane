# 钉钉机器人 Access Token
# 钉钉群 → 智能群助手 → 添加自定义机器人 → 复制 access_token
DINGTALK_TOKEN=你的TOKEN

# 推送阈值（0-40，>= 此分才推送）
# 30+ = 金狗推荐  26+ = 可关注  20+ = 观望  20- = 回避
MIN_SCORE=30

# 最小流动性（USD）
MIN_LIQUIDITY=50000

# Anthropic API Key（可选，设置后用 Claude 生成 AI 叙事分析）
# 获取: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# 代理地址（国内访问 Solana RPC 需要）
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
